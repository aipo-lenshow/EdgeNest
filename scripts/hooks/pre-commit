#!/usr/bin/env bash
# EdgeNest pre-commit privacy scanner.
#
# Blocks commits that introduce any of:
#   - RFC1918 IP literals (192.168.x.x / 10.x.x.x / 172.16-31.x.x)
#   - Long token-shaped strings (40+ chars [A-Za-z0-9_-], excluding obvious
#     non-secrets like commit/file hashes and Go module sums)
#   - Real personal identifiers (the owner's macOS username / private hostnames)
#
# False-positive allowlist (must contain RFC1918 / "lenshow" literals to do
# their job — these files are intentionally skipped):
#   - scripts/hooks/pre-commit (this scanner)
#   - .github/workflows/scan.yml (CI mirror of this scanner)
#
# Allowed strings even outside the allowlist:
#   - "aipo-lenshow" (GitHub org name)
#   - "ailenshow.com" (project domain)
set -euo pipefail

# Files to scan = staged + added/modified, excluding the allowlist and binaries.
# Uses while-read instead of mapfile/readarray for macOS bash 3.2 compatibility.
ALLOWLIST_RE='^(scripts/hooks/pre-commit|\.github/workflows/scan\.yml)$'
FILES=()
while IFS= read -r line; do
  [ -n "$line" ] && FILES+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACMR | grep -Ev "$ALLOWLIST_RE" || true)
[ ${#FILES[@]} -eq 0 ] && exit 0

FAIL=0
report() { FAIL=1; printf '  %s\n' "$1"; }

# 1) RFC1918 private IPs.
RFC1918='(\b192\.168\.[0-9]{1,3}\.[0-9]{1,3}\b|\b10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\b|\b172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9]{1,3}\.[0-9]{1,3}\b)'

# 2) Long token-shaped strings (40+ chars). Pre-filters out common false-positives:
#    - go.sum lines (look like "h1:<base64>")
#    - lines that are just a hex hash (commit SHA, file checksum)
TOKEN='[A-Za-z0-9_-]{40,}'

# 3) Personal identifiers (owner's macOS username, private hostnames).
#    Excludes "aipo-lenshow" (GitHub org) and "ailenshow" (domain).
PERSONAL_LENSHOW='(^|[^a-z-])lenshow([^a-z.]|$)'
PRIVATE_HOSTS='(\baipo-dev\b|\bZ423\b)'

scan_file() {
  local f="$1"
  # Binary skip.
  if file "$f" 2>/dev/null | grep -q 'binary'; then return; fi

  # Test files (Go *_test.go, TS *.test.ts/.tsx, *.spec.ts/.tsx) contain
  # synthetic fixtures (Reality keys, WARP endpoints, route CIDR examples)
  # that swamp the privacy signal. The PERSONAL_LENSHOW + PRIVATE_HOSTS
  # checks below still apply — those have no legitimate place in tests.
  local is_test=0
  case "$f" in
    *_test.go|*.test.ts|*.test.tsx|*.spec.ts|*.spec.tsx) is_test=1 ;;
  esac

  # RFC1918.
  if [ "$is_test" -eq 0 ]; then
    if hits=$(grep -nE "$RFC1918" "$f" 2>/dev/null); then
      report "RFC1918 IP in $f:"
      while IFS= read -r line; do printf '    %s\n' "$line"; done <<< "$hits"
    fi
  fi

  # Tokens. Skip go.sum / go.mod (legitimate base64-like sums) and tests.
  case "$f" in
    go.sum|go.mod|web/package-lock.json|web/package.json) ;;
    *)
      if [ "$is_test" -eq 0 ]; then
        # Match long tokens NOT preceded by typical non-secret prefixes.
        if hits=$(grep -nE "$TOKEN" "$f" 2>/dev/null \
                  | grep -Ev '(commit|sha|hash|h1:|sha256-|integrity|resolved)' \
                  | grep -Ev 'go\.sum|test-fixture' \
                  | grep -Ev '^[0-9]+:[[:space:]]*[#/*-]+[[:space:]]*-{4,}[[:space:]]*[#/*-]*[[:space:]]*$' ); then
          if [ -n "$hits" ]; then
            report "Possible token (40+ chars) in $f:"
            while IFS= read -r line; do printf '    %s\n' "$line"; done <<< "$hits"
          fi
        fi
      fi
      ;;
  esac

  # Personal lenshow.
  if hits=$(grep -nE "$PERSONAL_LENSHOW" "$f" 2>/dev/null | grep -vE 'aipo-lenshow|ailenshow'); then
    if [ -n "$hits" ]; then
      report "Personal identifier 'lenshow' in $f (use 'aipo-lenshow'/'ailenshow' instead):"
      while IFS= read -r line; do printf '    %s\n' "$line"; done <<< "$hits"
    fi
  fi

  # Private hosts.
  if hits=$(grep -nE "$PRIVATE_HOSTS" "$f" 2>/dev/null); then
    report "Private host name in $f:"
    while IFS= read -r line; do printf '    %s\n' "$line"; done <<< "$hits"
  fi
}

for f in "${FILES[@]}"; do
  [ -f "$f" ] || continue
  scan_file "$f"
done

if [ "$FAIL" -ne 0 ]; then
  echo
  echo "❌ pre-commit privacy scan failed. Fix the matches above and re-stage."
  echo "   To bypass intentionally (NOT recommended): git commit --no-verify"
  exit 1
fi
exit 0
